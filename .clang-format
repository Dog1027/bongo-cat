{
    BasedOnStyle: WebKit,
    IndentWidth: 4,
    UseTab: Never,
    PointerAlignment: Right,
    SortIncludes: false,
    BreakBeforeBraces: Custom,
    BraceWrapping: {
        BeforeElse: true,
        AfterFunction: true,
    },
    AlignConsecutiveMacros: {
        Enabled: true
    }
}
